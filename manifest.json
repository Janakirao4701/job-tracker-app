{
  "manifest_version": 3,
  "name": "Job Application Tracker",
  "version": "1.0.1",
  "description": "Premium AI-powered job application tracker with cloud sync, Gemini extraction, and beautiful UI",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardRead",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/",
    "https://dxsdvzhnqbynicrvbcfi.supabase.co/",
    "https://job-tracker-app-iota-beryl.vercel.app/"
  ],
  "action": {
    "default_popup": "src/pages/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/scripts/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "toggle_sidebar": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "mac": "Alt+Shift+T"
      },
      "description": "Open or close the tracker sidebar"
    },
    "extract_save": {
      "suggested_key": {
        "default": "Alt+Shift+E",
        "mac": "Alt+Shift+E"
      },
      "description": "Extract & Save current job"
    },
    "new_app": {
      "suggested_key": {
        "default": "Alt+Shift+N",
        "mac": "Alt+Shift+N"
      },
      "description": "Open new application form"
    },
    "open_settings": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "Open settings"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/lib/config.js",
        "src/lib/logger.js",
        "src/lib/docx-bundle.js",
        "src/lib/FileSaver.min.js",
        "src/lib/resume-engine.js",
        "src/scripts/content.js",
        "src/scripts/copilot.js"
      ],
      "css": [
        "src/styles/sidebar.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/lib/docx-bundle.js",
        "src/lib/FileSaver.min.js",
        "src/lib/resume-engine.js",
        "src/lib/xlsxbuilder.js",
        "src/pages/app.html",
        "src/pages/privacy.html",
        "public/icons/icon16.png",
        "public/icons/icon32.png",
        "public/icons/icon48.png",
        "public/icons/icon128.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "externally_connectable": {
    "matches": [
      "https://job-tracker-app-iota-beryl.vercel.app/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "options_page": "src/pages/app.html"
}